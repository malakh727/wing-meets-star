---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const all = await getCollection("writing");
const posts = all
  .filter((p) => p.id.startsWith("en/") && !p.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout title="Writing" description="Essays and notes on engineering, craft, and curiosity.">
  <div class="max-w-3xl mx-auto px-6 py-20">

    <header class="mb-16">
      <p class="font-label text-xs text-primary uppercase tracking-widest mb-3">Writing</p>
      <h1 class="font-display font-semibold text-on-surface" style="font-size: 3rem; letter-spacing: -0.02em;">
        Knowledge Garden
      </h1>
      <p class="font-body text-lg text-on-surface-muted mt-4 leading-relaxed max-w-lg">
        Long-form essays and short evolving notes — ideas at different stages of growth.
      </p>
    </header>

    {posts.length === 0 ? (
      <p class="font-label text-sm text-on-surface-muted text-center py-12">
        Nothing here yet — check back soon.
      </p>
    ) : (
      <ol class="space-y-1">
        {posts.map((post) => {
          const slug = post.id.slice(3);
          const date = new Date(post.data.date).toLocaleDateString("en-US", {
            year: "numeric",
            month: "long",
            day: "numeric",
          });
          return (
            <li>
              <a
                href={`/blog/${slug}`}
                class="group flex flex-col sm:flex-row sm:items-baseline gap-2 sm:gap-6 py-5 px-4 -mx-4 rounded transition-colors duration-200 hover:bg-surface-low card-glow"
              >
                <time class="font-label text-sm text-on-surface-muted shrink-0 mt-1 sm:w-36">
                  {date}
                </time>
                <div class="flex-1">
                  <div class="flex items-baseline gap-2 mb-0.5">
                    <h2 class="font-body text-xl text-on-surface group-hover:text-primary transition-colors duration-200 leading-snug">
                      {post.data.title}
                    </h2>
                    <span
                      class="font-label text-xs shrink-0"
                      style={post.data.type === "essay"
                        ? "color: #adc6ff; opacity: 0.7;"
                        : "color: #E9C176; opacity: 0.7;"}
                    >
                      {post.data.type}
                    </span>
                  </div>
                  {post.data.description && (
                    <p class="font-body text-base text-on-surface-muted mt-1 leading-relaxed">
                      {post.data.description}
                    </p>
                  )}
                  {post.data.tags && (
                    <div class="flex flex-wrap gap-2 mt-2">
                      {post.data.tags.map((tag) => (
                        <span class="font-label text-xs text-on-surface-muted px-2 py-0.5 rounded" style="background-color: #2A2A2A;">
                          {tag}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
              </a>
            </li>
          );
        })}
      </ol>
    )}

  </div>
</BaseLayout>
