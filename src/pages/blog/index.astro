---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Blog" description="Long-form essays on engineering, craft, and curiosity.">
  <div class="max-w-3xl mx-auto px-6 py-20">
    <header class="mb-16">
      <p class="font-label text-xs text-primary uppercase tracking-widest mb-3">Essays</p>
      <h1
        class="font-display font-semibold text-on-surface"
        style="font-size: 2.5rem; letter-spacing: -0.02em;"
      >
        Blog
      </h1>
      <p class="font-body text-base text-on-surface-muted mt-4 leading-relaxed max-w-lg">
        Long-form thinking on engineering, craft, and curiosity. Ideas that took time to form.
      </p>
    </header>

    <!-- Placeholder — posts will come in Phase 3 -->
    <div class="space-y-px">
      <div class="py-12 text-center">
        <span class="font-label text-sm text-on-surface-muted" style="letter-spacing: 0.05em;">
          No posts yet — check back soon.
        </span>
      </div>
    </div>
  </div>
</BaseLayout>
