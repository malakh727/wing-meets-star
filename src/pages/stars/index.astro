---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import StarMap from "../../components/StarMap.tsx";
import type { StarData } from "../../components/StarMap.tsx";

const stories = await getCollection("stars");
const posts = stories
  .filter((s) => s.id.startsWith("en/") && !s.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

// Only stories with map coordinates appear on the constellation
const mappedStars: StarData[] = posts
  .filter((s) => s.data.x != null && s.data.y != null)
  .map((s) => ({
    slug: s.id.slice(3),
    title: s.data.title,
    description: s.data.description,
    x: s.data.x!,
    y: s.data.y!,
    href: `/stars/${s.id.slice(3)}`,
  }));
---

<BaseLayout title="Stars" description="Creative storytelling through an interactive constellation.">
  <div class="max-w-4xl mx-auto px-6 py-20">
    <header class="mb-12">
      <p class="font-label text-xs text-tertiary uppercase tracking-widest mb-3">Constellation</p>
      <h1
        class="font-display font-semibold text-on-surface"
        style="font-size: 3rem; letter-spacing: -0.02em;"
      >
        Star Stories
      </h1>
      <p class="font-body text-lg text-on-surface-muted mt-4 leading-relaxed max-w-lg">
        Short fictions set in the space between what we know and what we feel.
        Hover a star. Click to read.
      </p>
    </header>

    <!-- Interactive star map -->
    {
      mappedStars.length > 0 && (
        <div class="mb-16">
          <StarMap client:load stars={mappedStars} />
        </div>
      )
    }

    <!-- Story list -->
    <section>
      <p
        class="font-label text-xs text-on-surface-muted uppercase tracking-widest mb-6"
      >
        All Stories
      </p>
      {
        posts.length === 0 ? (
          <p class="font-label text-sm text-on-surface-muted text-center py-12">
            No stories yet — the sky is being mapped.
          </p>
        ) : (
          <ol class="space-y-1">
            {posts.map((story) => {
              const slug = story.id.slice(3);
              const date = new Date(story.data.date).toLocaleDateString("en-US", {
                year: "numeric",
                month: "long",
                day: "numeric",
              });
              return (
                <li>
                  <a
                    href={`/stars/${slug}`}
                    class="group flex flex-col sm:flex-row sm:items-baseline gap-2 sm:gap-6 py-5 px-4 -mx-4 rounded transition-colors duration-200 hover:bg-surface-low card-glow"
                  >
                    <time class="font-label text-sm text-on-surface-muted shrink-0 mt-1 sm:w-36">
                      {date}
                    </time>
                    <div class="flex-1">
                      <h2 class="font-body text-xl text-on-surface group-hover:text-tertiary transition-colors duration-200 leading-snug">
                        {story.data.title}
                      </h2>
                      {story.data.description && (
                        <p class="font-body text-base text-on-surface-muted mt-1 leading-relaxed">
                          {story.data.description}
                        </p>
                      )}
                    </div>
                    <span class="text-tertiary opacity-40 group-hover:opacity-80 transition-opacity text-sm self-center">
                      ✦
                    </span>
                  </a>
                </li>
              );
            })}
          </ol>
        )
      }
    </section>
  </div>
</BaseLayout>
