---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Stars" description="Creative storytelling through an interactive constellation.">
  <div class="max-w-3xl mx-auto px-6 py-20">
    <header class="mb-16">
      <p class="font-label text-xs text-tertiary uppercase tracking-widest mb-3">Constellation</p>
      <h1
        class="font-display font-semibold text-on-surface"
        style="font-size: 2.5rem; letter-spacing: -0.02em;"
      >
        Star Stories
      </h1>
      <p class="font-body text-base text-on-surface-muted mt-4 leading-relaxed max-w-lg">
        Creative storytelling where each star holds a story. The interactive star map is coming in a future phase.
      </p>
    </header>

    <!-- Preview of star map area -->
    <div
      class="relative w-full h-64 rounded flex items-center justify-center overflow-hidden"
      style="background-color: #1C1B1B;"
    >
      <!-- Mini starfield -->
      {
        Array.from({ length: 30 }).map((_, i) => (
          <div
            class="absolute w-0.5 h-0.5 rounded-full bg-on-surface-muted"
            style={`
              top: ${Math.sin(i * 2.5) * 40 + 50}%;
              left: ${(i / 30) * 100}%;
              opacity: ${0.2 + (i % 5) * 0.12};
            `}
          />
        ))
      }
      <div class="relative text-center space-y-2">
        <span class="text-4xl" style="color: #E9C176;">✦</span>
        <p class="font-label text-xs text-on-surface-muted" style="letter-spacing: 0.08em;">
          INTERACTIVE STAR MAP — COMING SOON
        </p>
      </div>
    </div>
  </div>
</BaseLayout>
