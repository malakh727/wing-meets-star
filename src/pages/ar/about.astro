---
import { getEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const about = (await getEntry("about", "ar"))!;
const { greeting, name, intro, sections, closing, builtWith, title, description } = about.data;
---

<BaseLayout {title} {description} lang="ar">
  <div class="max-w-2xl mx-auto px-6 py-20">

    <!-- Header -->
    <header class="mb-20">
      <p class="font-label text-sm text-primary uppercase tracking-widest mb-4">عني</p>
      <h1 class="font-display font-semibold text-on-surface" style="font-size: 3.5rem; letter-spacing: -0.01em; line-height: 1.2;">
        {greeting}
      </h1>
      <p class="font-body text-2xl text-on-surface-muted mt-4 leading-relaxed">
        {name}
      </p>
    </header>

    <!-- Intro -->
    <div class="mb-20 ps-5" style="border-inline-start: 2px solid var(--color-primary);">
      <p class="font-body text-lg text-on-surface leading-relaxed">
        {intro}
      </p>
    </div>

    <!-- Sections -->
    <div class="space-y-16">
      {sections.map((section, i) => (
        <div>
          <div class="flex items-center gap-3 mb-6">
            <span class="font-label text-base text-primary" style="opacity: 0.5; font-variant-numeric: tabular-nums; min-width: 1.6rem;">
              {String(i + 1).padStart(2, "0")}
            </span>
            <h2 class="font-label text-sm text-on-surface uppercase tracking-widest">
              {section.label}
            </h2>
          </div>
          <div class="space-y-5 ps-9">
            {section.paragraphs.map((p) => (
              <p class="font-body text-lg text-on-surface-muted leading-relaxed">{p}</p>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Closing -->
    <div class="mt-24 p-7 rounded bg-surface-low" style="border-inline-start: 2px solid var(--color-tertiary);">
      <p class="font-body text-lg text-on-surface-muted leading-relaxed italic">
        {closing}
      </p>
    </div>

    <!-- Built with -->
    <div class="mt-10">
      <p class="font-label text-xs text-on-surface-muted" style="letter-spacing: 0.05em; opacity: 0.35;">
        {builtWith}
      </p>
    </div>

  </div>
</BaseLayout>
