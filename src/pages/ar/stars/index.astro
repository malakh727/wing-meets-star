---
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout title="النجوم" lang="ar">
  <div class="max-w-3xl mx-auto px-6 py-20">
    <header class="mb-16">
      <p class="font-label text-xs text-tertiary uppercase tracking-widest mb-3">كوكبة</p>
      <h1 class="font-display font-semibold text-on-surface" style="font-size: 2.5rem; letter-spacing: -0.01em;">
        قصص النجوم
      </h1>
      <p class="font-body text-base text-on-surface-muted mt-4 leading-relaxed max-w-lg">
        قصص إبداعية تحملها النجوم. خريطة النجوم التفاعلية قادمة.
      </p>
    </header>

    <div class="relative w-full h-64 rounded flex items-center justify-center overflow-hidden" style="background-color: #1C1B1B;">
      <div class="relative text-center space-y-2">
        <span class="text-4xl" style="color: #E9C176;">✦</span>
        <p class="font-label text-xs text-on-surface-muted" style="letter-spacing: 0.08em;">
          خريطة النجوم التفاعلية — قريباً
        </p>
      </div>
    </div>
  </div>
</BaseLayout>
