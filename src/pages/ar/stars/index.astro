---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";

const stories = await getCollection("stars");
const posts = stories
  .filter((s) => s.id.startsWith("ar/") && !s.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout title="النجوم" lang="ar">
  <div class="max-w-3xl mx-auto px-6 py-20">
    <header class="mb-16">
      <p class="font-label text-xs text-tertiary uppercase tracking-widest mb-3">كوكبة</p>
      <h1
        class="font-display font-semibold text-on-surface"
        style="font-size: 3rem; letter-spacing: -0.01em;"
      >
        قصص النجوم
      </h1>
      <p class="font-body text-lg text-on-surface-muted mt-4 leading-relaxed max-w-lg">
        قصص قصيرة في المساحة بين ما نعرفه وما نشعر به.
      </p>
    </header>

    {
      posts.length === 0 ? (
        <p class="font-label text-sm text-on-surface-muted text-center py-12">
          لا توجد قصص بعد — السماء تُرسم.
        </p>
      ) : (
        <ol class="space-y-1">
          {posts.map((story) => {
            const slug = story.id.slice(3);
            const date = new Date(story.data.date).toLocaleDateString("ar-SA", {
              year: "numeric",
              month: "long",
              day: "numeric",
            });
            return (
              <li>
                <a
                  href={`/ar/stars/${slug}`}
                  class="group flex flex-col sm:flex-row sm:items-baseline gap-2 sm:gap-6 py-5 px-4 -mx-4 rounded transition-colors duration-200 hover:bg-surface-low card-glow"
                >
                  <time class="font-label text-sm text-on-surface-muted shrink-0 mt-1 sm:w-40">
                    {date}
                  </time>
                  <div class="flex-1">
                    <h2 class="font-body text-xl text-on-surface group-hover:text-tertiary transition-colors duration-200 leading-snug">
                      {story.data.title}
                    </h2>
                    {story.data.description && (
                      <p class="font-body text-base text-on-surface-muted mt-1 leading-relaxed">
                        {story.data.description}
                      </p>
                    )}
                  </div>
                  <span class="text-tertiary opacity-40 group-hover:opacity-80 transition-opacity text-sm">✦</span>
                </a>
              </li>
            );
          })}
        </ol>
      )
    }
  </div>
</BaseLayout>
