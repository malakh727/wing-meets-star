---
import { getEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const p = (await getEntry("portfolio", "ar"))!;
const { title, description, summary, experience, projects, skillGroups, education, activities, contact } = p.data;
---

<BaseLayout {title} {description} lang="ar">
  <div class="max-w-4xl mx-auto px-6 py-20">

    <!-- Header -->
    <header class="mb-20">
      <p class="font-label text-xs text-primary uppercase tracking-widest mb-3">العمل</p>
      <h1 class="font-display font-semibold text-on-surface" style="font-size: 2.5rem; letter-spacing: -0.01em;">
        ملف الأعمال
      </h1>
      <p class="font-body text-base text-on-surface-muted mt-4 leading-relaxed max-w-2xl">
        {summary}
      </p>
    </header>

    <!-- Experience -->
    <section class="mb-20">
      <h2 class="font-label text-xs text-on-surface-muted uppercase tracking-widest mb-10">الخبرة</h2>
      {experience.map((job) => (
        <div class="relative pe-6 border-e border-outline-variant">
          <div class="absolute -end-1 top-1.5 w-2 h-2 rounded-full bg-primary opacity-60" />
          <div class="mb-2 flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1">
            <div>
              <span class="font-display font-semibold text-on-surface" style="font-size: 1.1rem;">{job.role}</span>
              <span class="font-body text-on-surface-muted"> — </span>
              <span class="font-body text-tertiary">{job.company}</span>
            </div>
            <span class="font-label text-xs text-on-surface-muted shrink-0">{job.period}</span>
          </div>
          <p class="font-label text-xs text-on-surface-muted mb-4" style="letter-spacing: 0.03em;">{job.location}</p>
          <ul class="space-y-2">
            {job.bullets.map((b) => (
              <li class="flex gap-3">
                <span class="text-primary mt-1 shrink-0" style="font-size: 0.5rem;">●</span>
                <span class="font-body text-sm text-on-surface-muted leading-relaxed">{b}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </section>

    <!-- Projects -->
    <section class="mb-20">
      <h2 class="font-label text-xs text-on-surface-muted uppercase tracking-widest mb-10">المشاريع</h2>
      <div class="grid md:grid-cols-2 gap-4">
        {projects.map((proj) => (
          <div class="p-6 rounded bg-surface-low card-glow flex flex-col gap-4">
            <div>
              <div class="flex items-start justify-between gap-2 mb-1">
                <h3 class="font-display font-semibold text-on-surface" style="font-size: 1rem;">{proj.name}</h3>
                <span class="font-label text-xs text-tertiary shrink-0 mt-0.5">{proj.type}</span>
              </div>
              <div class="flex flex-wrap gap-1.5 mb-3">
                {proj.stack.map((s) => (
                  <span class="font-label text-xs text-on-surface-muted px-2 py-0.5 rounded" style="background-color: #2A2A2A;">{s}</span>
                ))}
              </div>
              <p class="font-body text-sm text-on-surface-muted leading-relaxed">{proj.description}</p>
            </div>
            <div class="flex gap-3 mt-auto">
              <a href={proj.repo} target="_blank" rel="noopener noreferrer" class="font-label text-xs text-primary hover:opacity-80 transition-opacity" style="letter-spacing: 0.03em;">
                عرض على GitHub ↗
              </a>
              {proj.liveUrl && (
                <a href={proj.liveUrl} target="_blank" rel="noopener noreferrer" class="font-label text-xs text-tertiary hover:opacity-80 transition-opacity" style="letter-spacing: 0.03em;">
                  عرض مباشر ↗
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Skills -->
    <section class="mb-20">
      <h2 class="font-label text-xs text-on-surface-muted uppercase tracking-widest mb-10">المهارات</h2>
      <div class="space-y-5">
        {skillGroups.map((group) => (
          <div class="flex flex-col sm:flex-row sm:items-start gap-2 sm:gap-6">
            <span class="font-label text-xs text-on-surface-muted shrink-0 sm:w-36 pt-1" style="letter-spacing: 0.03em;">
              {group.label}
            </span>
            <div class="flex flex-wrap gap-2">
              {group.skills.map((s) => (
                <span class="font-label text-xs text-on-surface-muted px-3 py-1.5 rounded" style="background-color: #2A2A2A; letter-spacing: 0.02em;">{s}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Education -->
    <section class="mb-20">
      <h2 class="font-label text-xs text-on-surface-muted uppercase tracking-widest mb-10">التعليم</h2>
      <div class="space-y-6">
        {education.map((e) => (
          <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1">
            <div>
              <p class="font-body text-base text-on-surface leading-snug">{e.degree}</p>
              <p class="font-label text-xs text-on-surface-muted mt-1" style="letter-spacing: 0.03em;">{e.school}</p>
              {e.note && <p class="font-label text-xs text-primary mt-1">{e.note}</p>}
            </div>
            <span class="font-label text-xs text-on-surface-muted shrink-0">{e.period}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- Leadership & Activities -->
    <section class="mb-20">
      <h2 class="font-label text-xs text-on-surface-muted uppercase tracking-widest mb-10">القيادة والأنشطة</h2>
      <ul class="space-y-3">
        {activities.map((a) => (
          <li class="flex gap-3">
            <span class="text-tertiary mt-1 shrink-0" style="font-size: 0.5rem;">●</span>
            <span class="font-body text-sm text-on-surface-muted leading-relaxed">
              {a.text}{a.links && " "}
              {a.links?.map((l, i) => (
                <>
                  <a href={l.href} target="_blank" rel="noopener noreferrer" class="text-primary hover:opacity-80 transition-opacity">{l.label}</a>
                  {i < a.links!.length - 1 && <span> · </span>}
                </>
              ))}
            </span>
          </li>
        ))}
      </ul>
    </section>

    <!-- Contact -->
    <section>
      <h2 class="font-label text-xs text-on-surface-muted uppercase tracking-widest mb-6">التواصل</h2>
      <div class="flex flex-wrap gap-6">
        {contact.map((c) => (
          <a
            href={c.href}
            target={c.href.startsWith("mailto") ? undefined : "_blank"}
            rel="noopener noreferrer"
            class="font-label text-sm text-on-surface-muted hover:text-primary transition-colors duration-200"
            style="letter-spacing: 0.03em;"
          >
            {c.label} {c.icon}
          </a>
        ))}
      </div>
    </section>

  </div>
</BaseLayout>
