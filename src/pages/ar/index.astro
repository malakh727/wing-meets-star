---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="الرئيسية" lang="ar">
  <!-- Hero -->
  <section class="relative min-h-[80vh] flex items-center overflow-hidden">
    <div
      class="absolute inset-0 pointer-events-none"
      style="
        background-image:
          linear-gradient(rgba(66,71,84,0.05) 1px, transparent 1px),
          linear-gradient(90deg, rgba(66,71,84,0.05) 1px, transparent 1px);
        background-size: 24px 24px;
      "
    ></div>

    <div
      class="absolute top-1/3 right-1/4 w-96 h-96 rounded-full pointer-events-none"
      style="background: radial-gradient(circle, rgba(173,198,255,0.04) 0%, transparent 70%);"
    ></div>

    <div class="relative max-w-6xl mx-auto px-6 py-24 w-full">
      <div class="grid md:grid-cols-5 gap-12 items-center">
        <!-- Right text (RTL: displayed on right) -->
        <div class="md:col-span-3 space-y-6">
          <p class="font-label text-xs text-primary uppercase tracking-widest">
            حديقة المعرفة
          </p>

          <h1
            class="font-display font-semibold text-on-surface leading-tight"
            style="font-size: 3.5rem; letter-spacing: -0.01em; line-height: 1.2;"
          >
            حيث يلتقي الجناح<br />
            <span style="color: #E9C176;">بالنجمة.</span><img
              src="/assets/wing-meet-star-logo-removebg.png"
              alt="Wing Meets Star logo"
              style="display: inline-block; height: 1.5em; vertical-align: middle; margin-right: 0.1em; animation: logoFloat 1.8s ease-in-out infinite;"
            />
          </h1>

          <p class="font-body text-lg text-on-surface-muted leading-relaxed max-w-md">
            مكان تنمو فيه الأفكار، وتتواصل المعرفة كالنجوم، ويلتقي الهندسة بالفضول.
          </p>

          <div class="flex flex-wrap gap-4 pt-2">
            <a
              href="/ar/blog"
              class="font-label text-sm uppercase tracking-wider px-5 py-2.5 rounded text-surface font-medium"
              style="background: linear-gradient(135deg, #adc6ff, #4D8EFF); letter-spacing: 0.03em;"
            >
              المقالات
            </a>
            <a
              href="/ar/garden"
              class="font-label text-sm px-5 py-2.5 rounded text-on-surface font-medium"
              style="background-color: #2A2A2A; outline: 1px solid rgba(66,71,84,0.15);"
            >
              الحديقة
            </a>
          </div>
        </div>

        <!-- Decorative side — orrery -->
        <div class="md:col-span-2 hidden md:flex items-center justify-center">
          <div class="relative w-64 h-64">

            <!-- Outer ring -->
            <div class="absolute inset-0 rounded-full" style="border: 1px solid rgba(173,198,255,0.1);"></div>
            <div class="absolute inset-0 rounded-full orbit-cw-slow">
              <div class="orbit-dot" style="width:6px;height:6px;top:-3px;left:calc(50% - 3px);background:#adc6ff;box-shadow:0 0 6px 2px rgba(173,198,255,0.5);"></div>
            </div>

            <!-- Middle ring -->
            <div class="absolute inset-8 rounded-full" style="border: 1px dashed rgba(173,198,255,0.12);"></div>
            <div class="absolute inset-8 rounded-full orbit-ccw-med">
              <div class="orbit-dot" style="width:5px;height:5px;top:-2.5px;left:calc(50% - 2.5px);background:#E9C176;box-shadow:0 0 6px 2px rgba(233,193,118,0.5);"></div>
            </div>

            <!-- Inner ring -->
            <div class="absolute inset-16 rounded-full" style="border: 1px solid rgba(173,198,255,0.15);"></div>
            <div class="absolute inset-16 rounded-full orbit-cw-fast">
              <div class="orbit-dot" style="width:4px;height:4px;top:-2px;left:calc(50% - 2px);background:#b9c8de;box-shadow:0 0 4px 1px rgba(185,200,222,0.5);"></div>
            </div>

            <!-- Central star -->
            <div class="absolute inset-0 flex items-center justify-center">
              <span class="star-orrery" style="font-size: 2rem; color: #E9C176;">✦</span>
            </div>

          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Sections overview -->
  <section class="max-w-6xl mx-auto px-6 py-20">
    <h2
      class="font-display font-semibold text-on-surface-muted mb-12"
      style="font-size: 0.75rem; letter-spacing: 0.12em; text-transform: uppercase;"
    >
      استكشف
    </h2>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
      {
        [
          {
            href: "/ar/blog",
            label: "الكتابة",
            title: "حديقة المعرفة",
            desc: "مقالات وملاحظات قصيرة متطورة — أفكار في مراحل نمو مختلفة.",
            icon: "✍",
          },
          {
            href: "/ar/stars",
            label: "النجوم",
            title: "قصص النجوم",
            desc: "سرد إبداعي وكوكبة تفاعلية.",
            icon: "✦",
          },
          {
            href: "/ar/portfolio",
            label: "الأعمال",
            title: "ملف الأعمال",
            desc: "مشاريع ومهارات وخبرة مهنية.",
            icon: "◈",
          },
          {
            href: "/ar/about",
            label: "عني",
            title: "عني",
            desc: "مقدمة قصيرة عن العقل خلف هذه المساحة.",
            icon: "◎",
          },
        ].map((item) => (
          <a
            href={item.href}
            class="group block p-6 rounded bg-surface-low hover:bg-surface-high card-glow"
          >
            <div class="flex items-start gap-4">
              <span class="text-xl text-tertiary mt-0.5 opacity-70 group-hover:opacity-100 transition-opacity">
                {item.icon}
              </span>
              <div>
                <p class="font-label text-xs text-on-surface-muted uppercase tracking-wider mb-1">
                  {item.label}
                </p>
                <h3 class="font-body text-xl text-on-surface font-medium mb-2">
                  {item.title}
                </h3>
                <p class="font-body text-base text-on-surface-muted leading-relaxed">
                  {item.desc}
                </p>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  @keyframes logoFloat {
    0%, 100% { transform: translateY(0) rotate(0deg); opacity: 0.9; }
    50% { transform: translateY(-6px) rotate(3deg); opacity: 1; }
  }
</style>
