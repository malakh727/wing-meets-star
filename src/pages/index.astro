---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Home">
  <!-- Hero -->
  <section class="relative min-h-[80vh] flex items-center overflow-hidden">
    <!-- Technical grid overlay -->
    <div
      class="absolute inset-0 pointer-events-none"
      style="
        background-image:
          linear-gradient(rgba(66,71,84,0.05) 1px, transparent 1px),
          linear-gradient(90deg, rgba(66,71,84,0.05) 1px, transparent 1px);
        background-size: 24px 24px;
      "
    ></div>

    <!-- Ambient glow -->
    <div
      class="absolute top-1/3 left-1/4 w-96 h-96 rounded-full pointer-events-none"
      style="background: radial-gradient(circle, rgba(173,198,255,0.04) 0%, transparent 70%);"
    ></div>

    <div class="relative max-w-6xl mx-auto px-6 py-24 w-full">
      <!-- 60/40 asymmetric layout -->
      <div class="grid md:grid-cols-5 gap-12 items-center">
        <!-- Left: 60% -->
        <div class="md:col-span-3 space-y-6">
          <p class="font-label text-xs text-primary uppercase tracking-widest">
            Knowledge Garden
          </p>

          <h1
            class="font-display font-semibold text-on-surface leading-tight"
            style="font-size: 3.5rem; letter-spacing: -0.02em; line-height: 1.1;"
          >
            Where the wing<br />
            <span style="color: #E9C176;">meets the star.</span>
          </h1>

          <p class="font-body text-lg text-on-surface-muted leading-relaxed max-w-md">
            A space where ideas grow, knowledge connects like constellations,
            and engineering meets curiosity.
          </p>

          <div class="flex flex-wrap gap-4 pt-2">
            <a
              href="/blog"
              class="font-label text-sm uppercase tracking-wider px-5 py-2.5 rounded text-surface font-medium"
              style="background: linear-gradient(135deg, #adc6ff, #4D8EFF); letter-spacing: 0.05em;"
            >
              Read Essays
            </a>
            <a
              href="/garden"
              class="font-label text-sm uppercase tracking-wider px-5 py-2.5 rounded text-on-surface font-medium"
              style="background-color: #2A2A2A; letter-spacing: 0.05em; outline: 1px solid rgba(66,71,84,0.15);"
            >
              Visit Garden
            </a>
          </div>
        </div>

        <!-- Right: 40% — decorative void -->
        <div class="md:col-span-2 hidden md:flex items-center justify-center">
          <div class="relative w-64 h-64">
            <!-- Concentric rings -->
            <div
              class="absolute inset-0 rounded-full"
              style="border: 1px solid rgba(173,198,255,0.08);"
            ></div>
            <div
              class="absolute inset-8 rounded-full"
              style="border: 1px solid rgba(173,198,255,0.06);"
            ></div>
            <div
              class="absolute inset-16 rounded-full"
              style="border: 1px solid rgba(173,198,255,0.1);"
            ></div>
            <!-- Central star -->
            <div class="absolute inset-0 flex items-center justify-center">
              <span style="font-size: 2rem; color: #E9C176; opacity: 0.8;">✦</span>
            </div>
            <!-- Scattered dots -->
            <div class="absolute top-4 right-10 w-1 h-1 rounded-full bg-primary opacity-40"></div>
            <div class="absolute bottom-8 left-6 w-0.5 h-0.5 rounded-full bg-secondary opacity-50"></div>
            <div class="absolute top-16 left-4 w-1.5 h-1.5 rounded-full bg-tertiary opacity-30"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Sections overview -->
  <section class="max-w-6xl mx-auto px-6 py-20">
    <h2
      class="font-display font-semibold text-on-surface-muted mb-12"
      style="font-size: 0.75rem; letter-spacing: 0.12em; text-transform: uppercase;"
    >
      Explore
    </h2>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
      {
        [
          {
            href: "/blog",
            label: "Blog",
            title: "Essays",
            desc: "Long-form thinking on engineering, craft, and curiosity.",
            icon: "✍",
          },
          {
            href: "/garden",
            label: "Garden",
            title: "Knowledge Garden",
            desc: "Short, evolving notes that connect into a living map.",
            icon: "🌱",
          },
          {
            href: "/stars",
            label: "Stars",
            title: "Star Stories",
            desc: "Creative storytelling and an interactive constellation.",
            icon: "✦",
          },
          {
            href: "/portfolio",
            label: "Portfolio",
            title: "Work",
            desc: "Projects, skills, and professional experience.",
            icon: "◈",
          },
          {
            href: "/about",
            label: "About",
            title: "About",
            desc: "A brief introduction to the mind behind this space.",
            icon: "◎",
          },
        ].map((item) => (
          <a
            href={item.href}
            class="group block p-6 rounded bg-surface-low hover:bg-surface-high transition-colors duration-200"
          >
            <div class="flex items-start gap-4">
              <span class="text-xl text-tertiary mt-0.5 opacity-70 group-hover:opacity-100 transition-opacity">
                {item.icon}
              </span>
              <div>
                <p class="font-label text-xs text-on-surface-muted uppercase tracking-wider mb-1">
                  {item.label}
                </p>
                <h3
                  class="font-body text-lg text-on-surface font-medium mb-2"
                >
                  {item.title}
                </h3>
                <p class="font-body text-sm text-on-surface-muted leading-relaxed">
                  {item.desc}
                </p>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
