---
import { getEntry } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const about = (await getEntry("about", "en"))!;
const { greeting, name, intro, sections, closing, builtWith, title, description } = about.data;
---

<BaseLayout {title} {description}>
  <div class="max-w-2xl mx-auto px-6 py-20">

    <!-- Header -->
    <header class="mb-16">
      <p class="font-label text-xs text-primary uppercase tracking-widest mb-3">About</p>
      <h1 class="font-display font-semibold text-on-surface" style="font-size: 2.5rem; letter-spacing: -0.02em;">
        {greeting}
      </h1>
      <p class="font-body text-xl text-on-surface-muted mt-3 leading-relaxed">
        {name}
      </p>
    </header>

    <!-- Intro -->
    <div class="mb-16 ps-4" style="border-inline-start: 2px solid var(--color-primary); opacity: 0.9;">
      <p class="font-body text-base text-on-surface leading-relaxed">
        {intro}
      </p>
    </div>

    <!-- Sections -->
    <div class="space-y-14">
      {sections.map((section, i) => (
        <div>
          <div class="flex items-baseline gap-3 mb-4">
            <span class="font-label text-xs text-primary opacity-40" style="font-variant-numeric: tabular-nums;">
              {String(i + 1).padStart(2, "0")}
            </span>
            <p class="font-label text-xs text-on-surface-muted uppercase tracking-widest">
              {section.label}
            </p>
          </div>
          <div class="space-y-4 ps-6">
            {section.paragraphs.map((p) => (
              <p class="font-body text-base text-on-surface-muted leading-relaxed">{p}</p>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Closing -->
    <div class="mt-20 p-6 rounded bg-surface-low" style="border-inline-start: 2px solid var(--color-tertiary);">
      <p class="font-body text-base text-on-surface-muted leading-relaxed italic">
        {closing}
      </p>
    </div>

    <!-- Built with -->
    <div class="mt-10">
      <p class="font-label text-xs text-on-surface-muted" style="letter-spacing: 0.05em; opacity: 0.35;">
        {builtWith}
      </p>
    </div>

  </div>
</BaseLayout>
