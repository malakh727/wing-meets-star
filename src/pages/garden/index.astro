---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const notes = await getCollection("notes");
const posts = notes
  .filter((n) => n.id.startsWith("en/") && !n.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout title="Garden" description="A living map of short, interconnected ideas and notes.">
  <div class="max-w-3xl mx-auto px-6 py-20">
    <header class="mb-16">
      <p class="font-label text-xs text-primary uppercase tracking-widest mb-3">Notes</p>
      <h1
        class="font-display font-semibold text-on-surface"
        style="font-size: 3rem; letter-spacing: -0.02em;"
      >
        Knowledge Garden
      </h1>
      <p class="font-body text-lg text-on-surface-muted mt-4 leading-relaxed max-w-lg">
        Short, evolving notes. Ideas at different stages of growth.
      </p>
    </header>

    {
      posts.length === 0 ? (
        <p class="font-label text-sm text-on-surface-muted text-center py-12">
          The garden is being planted — come back soon.
        </p>
      ) : (
        <ol class="space-y-1">
          {posts.map((note) => {
            const slug = note.id.slice(3);
            const date = new Date(note.data.date).toLocaleDateString("en-US", {
              year: "numeric",
              month: "long",
              day: "numeric",
            });
            return (
              <li>
                <a
                  href={`/garden/${slug}`}
                  class="group flex flex-col sm:flex-row sm:items-baseline gap-2 sm:gap-6 py-5 px-4 -mx-4 rounded transition-colors duration-200 hover:bg-surface-low card-glow"
                >
                  <time class="font-label text-sm text-on-surface-muted shrink-0 mt-1 sm:w-36">
                    {date}
                  </time>
                  <div class="flex-1">
                    <h2 class="font-body text-xl text-on-surface group-hover:text-primary transition-colors duration-200 leading-snug">
                      {note.data.title}
                    </h2>
                    {note.data.description && (
                      <p class="font-body text-base text-on-surface-muted mt-1 leading-relaxed">
                        {note.data.description}
                      </p>
                    )}
                    {note.data.tags && (
                      <div class="flex flex-wrap gap-2 mt-2">
                        {note.data.tags.map((tag) => (
                          <span
                            class="font-label text-xs text-on-surface-muted px-2 py-0.5 rounded"
                            style="background-color: #2A2A2A;"
                          >
                            {tag}
                          </span>
                        ))}
                      </div>
                    )}
                  </div>
                </a>
              </li>
            );
          })}
        </ol>
      )
    }
  </div>
</BaseLayout>
