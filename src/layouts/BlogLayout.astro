---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description?: string;
  date?: string;
  lang?: "en" | "ar";
}

const { title, description, date, lang = "en" } = Astro.props;

const formattedDate = date
  ? new Date(date).toLocaleDateString(lang === "ar" ? "ar-SA" : "en-US", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : null;
---

<BaseLayout title={title} description={description} lang={lang}>
  <article class="max-w-3xl mx-auto px-6 py-20">
    <header class="mb-14">
      {
        formattedDate && (
          <time class="font-label text-sm text-on-surface-muted tracking-wider uppercase">
            {formattedDate}
          </time>
        )
      }
      <h1
        class="font-display text-5xl font-semibold tracking-tight text-on-surface mt-4 leading-tight"
        style="letter-spacing: -0.02em;"
      >
        {title}
      </h1>
      {
        description && (
          <p class="font-body text-xl text-on-surface-muted mt-5 leading-relaxed">
            {description}
          </p>
        )
      }
    </header>

    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>
