---
// No props — renders a fixed canvas starfield behind all page content
---

<canvas
  id="starfield"
  aria-hidden="true"
  style="position: fixed; inset: 0; width: 100%; height: 100%; pointer-events: none;"
></canvas>

<script>
  const canvas = document.getElementById("starfield") as HTMLCanvasElement;
  const ctx = canvas.getContext("2d")!;

  interface Star {
    x: number;
    y: number;
    r: number;
    baseOpacity: number;
    phase: number;
    speed: number;
    vx: number;
    vy: number;
    depth: number;
    sparkle: number;     // countdown to next sparkle (frames)
    sparkling: boolean;
    sparkleLife: number; // remaining sparkle frames
  }

  let stars: Star[] = [];
  let W = 0, H = 0;
  let mouseX = 0, mouseY = 0;
  let targetMouseX = 0, targetMouseY = 0;

  function resize() {
    W = canvas.width = window.innerWidth;
    H = canvas.height = window.innerHeight;
  }

  function makeStar(small: boolean): Star {
    const r = small
      ? Math.random() * 0.55 + 0.2
      : Math.random() * 0.7 + 0.85;
    return {
      x: Math.random() * W,
      y: Math.random() * H,
      r,
      baseOpacity: small
        ? Math.random() * 0.25 + 0.07
        : Math.random() * 0.2 + 0.32,
      phase: Math.random() * Math.PI * 2,
      speed: small ? Math.random() * 0.6 + 0.2 : Math.random() * 0.3 + 0.08,
      vx: (Math.random() - 0.5) * (small ? 0.14 : 0.22),
      vy: (Math.random() - 0.5) * (small ? 0.07 : 0.11),
      depth: r * (small ? 0.35 : 0.6),
      sparkle: Math.floor(Math.random() * 300 + 60),
      sparkling: false,
      sparkleLife: 0,
    };
  }

  function init() {
    resize();
    stars = [];
    for (let i = 0; i < 120; i++) stars.push(makeStar(true));
    for (let i = 0; i < 28; i++) stars.push(makeStar(false));
  }

  let t = 0;
  let frame = 0;

  function draw() {
    requestAnimationFrame(draw);
    frame++;
    if (frame % 2 !== 0) return; // ~30fps for smoother motion

    t += 0.018;
    mouseX += (targetMouseX - mouseX) * 0.04;
    mouseY += (targetMouseY - mouseY) * 0.04;

    ctx.clearRect(0, 0, W, H);

    for (const s of stars) {
      // Drift
      s.x += s.vx;
      s.y += s.vy;
      if (s.x < -4) s.x = W + 4;
      else if (s.x > W + 4) s.x = -4;
      if (s.y < -4) s.y = H + 4;
      else if (s.y > H + 4) s.y = -4;

      // Sparkle countdown
      if (!s.sparkling) {
        s.sparkle--;
        if (s.sparkle <= 0) {
          s.sparkling = true;
          s.sparkleLife = Math.floor(Math.random() * 10 + 6);
        }
      } else {
        s.sparkleLife--;
        if (s.sparkleLife <= 0) {
          s.sparkling = false;
          s.sparkle = Math.floor(Math.random() * 280 + 60);
        }
      }

      // Opacity: flicker + sparkle burst
      const flicker = Math.sin(t * s.speed * 3 + s.phase) * 0.16;
      let opacity = Math.max(0.04, Math.min(0.65, s.baseOpacity + flicker));
      if (s.sparkling) {
        const sparkProgress = s.sparkleLife / 16;
        opacity = Math.min(0.95, opacity + sparkProgress * 0.7);
      }

      // Parallax
      const px = mouseX * s.depth * 16;
      const py = mouseY * s.depth * 12;

      const drawX = s.x + px;
      const drawY = s.y + py;

      // Sparkle cross/bloom for accent stars
      if (s.sparkling && s.r > 0.7) {
        const bloom = s.sparkleLife / 16;
        ctx.save();
        ctx.globalAlpha = opacity * bloom * 0.5;
        const g = ctx.createRadialGradient(drawX, drawY, 0, drawX, drawY, s.r * 8);
        g.addColorStop(0, "rgba(229,226,225,0.8)");
        g.addColorStop(1, "transparent");
        ctx.fillStyle = g;
        ctx.beginPath();
        ctx.arc(drawX, drawY, s.r * 8, 0, Math.PI * 2);
        ctx.fill();
        ctx.restore();
      }

      ctx.beginPath();
      ctx.arc(drawX, drawY, s.r, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(229,226,225,${opacity.toFixed(3)})`;
      ctx.fill();
    }
  }

  init();
  draw();

  window.addEventListener("mousemove", (e) => {
    targetMouseX = (e.clientX / W - 0.5) * 2;
    targetMouseY = (e.clientY / H - 0.5) * 2;
  });

  window.addEventListener("resize", () => {
    resize();
    stars.forEach((s) => {
      s.x = Math.random() * W;
      s.y = Math.random() * H;
    });
  });
</script>
