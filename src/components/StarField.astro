---
// No props — renders a fixed canvas starfield behind all page content
---

<canvas
  id="starfield"
  aria-hidden="true"
  style="position: fixed; inset: 0; width: 100%; height: 100%; pointer-events: none;"
></canvas>

<script>
  const canvas = document.getElementById("starfield") as HTMLCanvasElement;
  const ctx = canvas.getContext("2d")!;

  interface Star {
    x: number;
    y: number;
    r: number;
    baseOpacity: number;
    phase: number;
    speed: number;
  }

  let stars: Star[] = [];
  let W = 0,
    H = 0;

  function resize() {
    W = canvas.width = window.innerWidth;
    H = canvas.height = window.innerHeight;
  }

  function init() {
    resize();
    stars = [];

    // Small background stars
    for (let i = 0; i < 90; i++) {
      stars.push({
        x: Math.random() * W,
        y: Math.random() * H,
        r: Math.random() * 0.5 + 0.2,
        baseOpacity: Math.random() * 0.2 + 0.08,
        phase: Math.random() * Math.PI * 2,
        speed: Math.random() * 0.4 + 0.1,
      });
    }

    // Accent stars — slightly brighter, larger
    for (let i = 0; i < 18; i++) {
      stars.push({
        x: Math.random() * W,
        y: Math.random() * H,
        r: Math.random() * 0.5 + 0.7,
        baseOpacity: Math.random() * 0.15 + 0.28,
        phase: Math.random() * Math.PI * 2,
        speed: Math.random() * 0.2 + 0.05,
      });
    }
  }

  let t = 0;
  let frame = 0;

  function draw() {
    requestAnimationFrame(draw);
    frame++;
    if (frame % 3 !== 0) return; // ~20fps — gentle, not distracting

    t += 0.016;
    ctx.clearRect(0, 0, W, H);

    for (const s of stars) {
      const flicker = Math.sin(t * s.speed * 3 + s.phase) * 0.1;
      const opacity = Math.max(0.04, Math.min(0.6, s.baseOpacity + flicker));
      ctx.beginPath();
      ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(229,226,225,${opacity.toFixed(3)})`;
      ctx.fill();
    }
  }

  init();
  draw();

  window.addEventListener("resize", () => {
    resize();
    // Re-scatter stars on resize
    stars.forEach((s) => {
      s.x = Math.random() * W;
      s.y = Math.random() * H;
    });
  });
</script>
