---
interface Props {
  lang?: "en" | "ar";
}

const { lang = "en" } = Astro.props;

const year = new Date().getFullYear();
---

<footer class="bg-surface-low mt-auto">
  <div
    class="max-w-6xl mx-auto px-6 py-10 flex flex-col md:flex-row items-center justify-between gap-4"
  >
    <a
      href={lang === "ar" ? "/ar/" : "/"}
      class="hover:opacity-70 transition-opacity duration-200"
      aria-label="Wing Meet Star — Home"
    >
      <img
        src="/assets/wing-meet-star-logo-removebg.png"
        alt="Wing Meet Star"
        class="h-14 w-auto opacity-60"
      />
    </a>

    <div class="flex items-center gap-6">
      <a
        href={lang === "ar" ? "/ar/blog" : "/blog"}
        class="font-label text-sm text-on-surface-muted hover:text-on-surface transition-colors"
      >
        {lang === "ar" ? "الكتابة" : "Writing"}
      </a>
      <a
        href={lang === "ar" ? "/ar/stars" : "/stars"}
        class="font-label text-sm text-on-surface-muted hover:text-on-surface transition-colors"
      >
        {lang === "ar" ? "النجوم" : "Stars"}
      </a>
    </div>

    <span class="font-label text-xs text-on-surface-muted">
      © {year}
    </span>
  </div>
</footer>
